# Database Configuration
DATABASE_URL=postgresql://drilling_user:drilling_password@localhost:5432/drilling_insight

# Frontend Configuration
# Backend AI service URL — must match the port uvicorn is started on (default: 8001)
VITE_AI_BASE_URL=http://localhost:8001

# JWT Configuration
# REQUIRED in production: generate a strong secret with `openssl rand -hex 32`
# The application will refuse to start if this is not set in production (APP_ENV=production).
SECRET_KEY=REPLACE_WITH_STRONG_RANDOM_SECRET
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application environment: set to "production" in deployed environments
APP_ENV=development

# CORS Configuration
# Comma-separated list of allowed frontend origins
# Frontend dev server runs on port 8080 by default (npm run dev)
# Also allow Vite default port 5173 and 127.0.0.1 variants for flexibility
AI_CORS_ORIGINS=http://localhost:8080,http://127.0.0.1:8080,http://localhost:5173,http://127.0.0.1:5173

# Logging
LOG_LEVEL=INFO

# Model Configuration
MODEL_PATH=models/recommendation_model.joblib
SCHEMA_PATH=models/schema.joblib
METRICS_PATH=models/metrics.json

# Safety Thresholds
CONFIDENCE_THRESHOLD=0.6
DLS_BLOCK_THRESHOLD=3.0
VIBRATION_CAUTION_MAX=0.5

# API Settings
API_TIMEOUT=30
