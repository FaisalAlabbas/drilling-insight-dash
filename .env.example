# Database Configuration
DATABASE_URL=postgresql://drilling_user:drilling_password@localhost:5432/drilling_insight

# Frontend Configuration
VITE_AI_BASE_URL=http://localhost:8001

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration
AI_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8080,http://127.0.0.1:8080

# Logging
LOG_LEVEL=INFO

# Model Configuration
MODEL_PATH=models/recommendation_model.joblib
SCHEMA_PATH=models/schema.joblib
METRICS_PATH=models/metrics.json

# Safety Thresholds
CONFIDENCE_THRESHOLD=0.6
DLS_BLOCK_THRESHOLD=3.0
VIBRATION_CAUTION_MAX=0.5

# API Settings
API_TIMEOUT=30